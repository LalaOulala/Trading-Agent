@startuml
skinparam classAttributeIconSize 0

package "agent_trade_sdk.config" {
class Settings {
  +openrouter_api_key: str | None
  +openrouter_model: str
  +openrouter_base_url: str
  +openai_tracing_api_key: str | None
  +tavily_api_key: str | None
  +perplexity_api_key: str | None
  +perplexity_model: str
  +alpaca_api_key: str | None
  +alpaca_secret_key: str | None
  +alpaca_paper: bool
  +alpaca_base_url: str
  +trading_allowed_symbols: tuple[str, ...]
  +trading_max_notional_usd: float | None
  +reflection_allow_behavior_autowrite: bool
  +from_env(require_openrouter: bool = True) Settings
}
}

package "agent_trade_sdk.agent" {
class TradingAgentBuilder <<module>> {
  +build_trading_agent(model_name: str | None = None) Agent
  +_load_soul_text(path: Path = SOUL_PATH) str
  +_load_behavior_text(path: Path = BEHAVIOR_PATH) str
}
}

package "agent_trade_sdk.tools.search" {
class SearchTools <<module>> {
  +tavily_search_raw(query, max_results, topic, time_range) dict
  +web_search_tavily(query, max_results, topic, time_range) str
  +_build_tavily_client() TavilyClient
}
}

package "agent_trade_sdk.tools.symbol_validation" {
class SymbolValidationTools <<module>> {
  +normalize_symbol(symbol) str
  +normalize_symbols_csv(symbols_csv) tuple[list[str], list[dict[str, str]]]
}
}

package "agent_trade_sdk.tools.market_data" {
class MarketDataTools <<module>> {
  +yfinance_quote_raw(symbol) dict
  +get_market_quote(symbol) str
  +yfinance_price_history_raw(symbol, period, interval, max_points) dict
  +get_price_history(symbol, period, interval, max_points) str
  +yfinance_market_snapshot_raw(symbols_csv) dict
  +get_market_snapshot(symbols_csv) str
}
}

package "agent_trade_sdk.tools.perplexity_snapshot" {
class PerplexitySnapshotTools <<module>> {
  +build_perplexity_snapshot_prompt(previous_summary_5_lines) str
  +perplexity_market_snapshot_raw() dict
  +compact_perplexity_snapshot_for_prompt(payload, max_sources) dict
  +_extract_summary_5_lines(snapshot_text) str
  +_persist_latest_summary(...) tuple[Path, Path] | None
}
}

package "agent_trade_sdk.tools.trading" {
class AlpacaConnectionConfig {
  +api_key: str
  +secret_key: str
  +paper: bool
  +base_url: str
  +allowed_symbols: tuple[str, ...]
  +max_notional_usd: float | None
  +from_env() AlpacaConnectionConfig
}

class AlpacaPaperBroker {
  +get_account() dict
  +get_positions() list
  +submit_market_order(symbol, side, qty, notional, time_in_force) dict
  +close_position(symbol) dict
}

class TradingTools <<module>> {
  +get_account_snapshot() str
  +list_open_positions() str
  +place_market_order(...) str
  +open_short_position(...) str
  +close_open_position(...) str
}
}

package "agent_trade_sdk.runner" {
class RunCycleResult {
  +final_output: str
  +log_path: Path
  +session_id: str
  +model_name: str
  +input_snapshot: dict
  +bootstrap_context: dict
  +runtime_summary: dict
  +short_memory_input: dict | None
  +memory_apply_result: MemoryApplyResult
  +post_run_memory_result: PostRunMemoryResult | None
}

class RunnerModule <<module>> {
  +run_once(prompt, model, log_dir, enable_tracing, session_id) RunCycleResult
  +run_loop(prompt, model, log_dir, enable_tracing, ...) None
  +_collect_input_snapshot() dict
  +_build_effective_prompt(user_prompt, snapshot, short_memory) str
  +_clamp_trace_payload(data) dict
  +_compact_runtime_summary_for_trace(runtime_summary) dict
  +main() None
}
}

package "agent_trade_sdk.memory_architecture" {
class TradingDecisionBlock {
  +action: BUY|SELL|SHORT|CLOSE|NO_TRADE
  +symbol: str | None
  +confidence: str | None
  +rationale: str
  +signal_principal: str | None
  +risk_identified: str | None
  +invalidation_condition: str | None
  +executed_order: dict | None
}

class LongMemoryUpdateIntent {
  +should_update_behavior: bool
  +why: str
  +update_summary: list[str]
  +updated_behavior_markdown: str | None
}

class TradingSessionLLMOutput {
  +trading_decision: TradingDecisionBlock
  +session_summary: str
  +decision_report: str
  +self_critique: str
  +pitfalls_to_avoid_next_run: list[str]
  +next_session_directives: list[str]
  +open_questions: list[str]
  +long_memory_update_intent: LongMemoryUpdateIntent
}

class ShortMemoryRecord {
  +generated_at_utc: str
  +source_session_id: str
  +model_name: str
  +session_summary: str
  +decision_report: str
  +self_critique: str
}

class BehaviorHistoryResult {
  +updated: bool
  +before_path: Path | None
  +after_path: Path | None
  +diff_path: Path | None
  +reason: str
  +summary: list[str]
}

class MemoryApplyResult {
  +parsed_output: TradingSessionLLMOutput | None
  +short_memory_latest_path: Path | None
  +short_memory_archive_path: Path | None
  +behavior_history: BehaviorHistoryResult | None
  +parse_error: str | None
  +summary_for_log() dict
}

class MemoryArchitecture <<module>> {
  +load_short_memory_latest() dict | None
  +load_behavior_text() str
  +parse_llm_trading_session_output(raw_text) TradingSessionLLMOutput
  +_extract_json_payload(raw_text) dict
  +apply_memory_outputs(raw_final_output, session_id, model_name, logs_root) MemoryApplyResult
  +short_memory_prompt_block(short_memory) str
}
}

package "agent_trade_sdk.post_run_memory" {
class PostRunMemoryResult {
  +journal_file_path: Path
  +reflection_latest_path: Path
  +reflection_archive_path: Path
  +behavior_updated: bool
}

class PostRunMemoryModule <<module>> {
  +run_post_run_memory_cycle(..., allow_behavior_autowrite, main_output_parse_error) PostRunMemoryResult
}
}

package "agent_trade_sdk.session_log" {
class SessionMarkdownLogger {
  +log_input_snapshot(snapshot) None
  +log_short_memory_input(short_memory) None
  +log_behavior_input(behavior_path, behavior_text) None
  +log_stream_event(event) None
  +log_final_output(output) None
  +log_memory_apply_result(payload) None
  +build_runtime_summary() dict
  +log_error(error) None
}
}

package "agent_trade_sdk.tracing_support" {
class TracingSupport <<module>> {
  +build_agents_run_config(...) RunConfig
  +build_trace_export_config(...) object
}
}

package "Memory Files" {
class "SOUL.md" as SoulFile <<artifact>>
class "behavior.md" as BehaviorFile <<artifact>>
class "memory/short/latest.json" as ShortMemoryFile <<artifact>>
class "memory/reflection/latest.json" as ReflectionFile <<artifact>>
class "memory/perplexity/latest_summary.json" as PerplexitySummaryFile <<artifact>>
class "logs/behaviors/*.md|*.diff" as BehaviorHistoryFiles <<artifact>>
}

class Agent <<external>>
class ModelSettings <<external>>
class LitellmModel <<external>>
class TavilyClient <<external>>
class "yf.Ticker" as YFinanceTicker <<external>>
class TradingClient <<external>>
class MarketOrderRequest <<external>>
class OrderSide <<external>>
class TimeInForce <<external>>
class "agents.Runner" as AgentsRunner <<external>>
class RunConfig <<external>>
class "agents.tracing.trace" as AgentsTrace <<external>>
class "agents.tracing.custom_span" as AgentsCustomSpan <<external>>
class AgentUpdatedStreamEvent <<external>>
class RawResponsesStreamEvent <<external>>
class RunItemStreamEvent <<external>>

TradingAgentBuilder --> Settings
TradingAgentBuilder --> LitellmModel
TradingAgentBuilder --> ModelSettings
TradingAgentBuilder --> SearchTools
TradingAgentBuilder --> MarketDataTools
TradingAgentBuilder --> TradingTools
TradingAgentBuilder --> Agent
TradingAgentBuilder --> SoulFile
TradingAgentBuilder --> BehaviorFile

RunnerModule --> TradingAgentBuilder
RunnerModule --> Settings
RunnerModule --> SessionMarkdownLogger
RunnerModule --> MemoryArchitecture
RunnerModule --> MemoryApplyResult
RunnerModule --> PostRunMemoryModule
RunnerModule --> PostRunMemoryResult
RunnerModule --> AlpacaPaperBroker
RunnerModule --> SearchTools : tavily_search_raw
RunnerModule --> MarketDataTools : yfinance_market_snapshot_raw
RunnerModule --> PerplexitySnapshotTools
RunnerModule --> AgentsRunner
RunnerModule --> TracingSupport
RunnerModule --> AgentsTrace
RunnerModule --> AgentsCustomSpan
RunnerModule --> RunCycleResult

SearchTools --> Settings
SearchTools --> TavilyClient
MarketDataTools --> YFinanceTicker
MarketDataTools --> SymbolValidationTools
PerplexitySnapshotTools --> Settings
PerplexitySnapshotTools --> PerplexitySummaryFile

TradingTools --> AlpacaPaperBroker
TradingTools --> SymbolValidationTools
AlpacaConnectionConfig --> Settings
AlpacaPaperBroker *-- AlpacaConnectionConfig
AlpacaPaperBroker --> TradingClient
AlpacaPaperBroker --> MarketOrderRequest
AlpacaPaperBroker --> OrderSide
AlpacaPaperBroker --> TimeInForce

SessionMarkdownLogger --> AgentUpdatedStreamEvent
SessionMarkdownLogger --> RawResponsesStreamEvent
SessionMarkdownLogger --> RunItemStreamEvent

MemoryArchitecture --> TradingSessionLLMOutput
TradingSessionLLMOutput *-- TradingDecisionBlock
TradingSessionLLMOutput *-- LongMemoryUpdateIntent
MemoryArchitecture --> ShortMemoryRecord
MemoryArchitecture --> MemoryApplyResult
MemoryApplyResult *-- BehaviorHistoryResult
MemoryArchitecture --> BehaviorFile
MemoryArchitecture --> ShortMemoryFile
MemoryArchitecture --> BehaviorHistoryFiles

PostRunMemoryModule --> ReflectionFile
RunnerModule --> PerplexitySummaryFile

@enduml
